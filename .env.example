# rtl_433 capture settings (verified for Fine Offset WHx080)
RTL_FREQUENCY=433.925M
RTL_SAMPLE_RATE=1000k
RTL_GAIN=40
RTL_EXTRA_FLAGS=-Y autolevel -Y magest

# Path to the rtl_433 binary inside the container; override only for local
# development where rtl_433 isn't on PATH.
RTL_433_PATH=rtl_433

# Storage
DATABASE_PATH=/data/weather.db

# 433MHz is unlicensed and unauthenticated, so anything transmitting in range
# (a neighbor's sensor, a car remote, a garage door) can produce a
# plausible-looking reading. Only readings whose model name contains this are
# accepted (empty string accepts any model). Once you know your sensor's id
# from /api/latest, set SENSOR_ID_FILTER to lock onto that one physical unit.
SENSOR_MODEL_FILTER=Fineoffset
SENSOR_ID_FILTER=

# Ingestion health
RESTART_BACKOFF_SECONDS=5
MAX_RESTART_BACKOFF_SECONDS=60
STALE_READING_SECONDS=180

# CORS (comma-separated origins, or * for any)
CORS_ORIGINS=*

# Set to DEBUG to log every raw rtl_433 JSON line (log rotation is configured
# in docker-compose.yml so this can't fill the disk).
LOG_LEVEL=INFO

# Host port published by docker-compose
WEB_PORT=8000
